# When the panel UI is exposed with a Cloudflare tunnel (windows/start-cloudflare-tunnel-ui.ps1),
# copy these lines into .env.local and restart `npm run dev`.
#
# Point the browser app at your EXISTING API tunnel (same URL remote agents use — do not add :3001 or /api).
# VITE_API_ORIGIN=https://typically-daughters-automotive-encountered.trycloudflare.com
#
# On the API host, add the UI tunnel origin to CORS_ALLOWED_ORIGINS, e.g.:
#   CORS_ALLOWED_ORIGINS=http://localhost:5173,https://YOUR-UI-TUNNEL.trycloudflare.com
