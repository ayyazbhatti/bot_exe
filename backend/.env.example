# Copy to .env or set in your process manager. Optional unless noted.

# HTTP port (default 3001)
# PORT=3001

# Public URL agents should use (optional). Set when you expose the API via a tunnel, e.g. cloudflared quick tunnel:
#   cloudflared tunnel --url http://localhost:3001
# Use the printed https://….trycloudflare.com URL here so the Remote Agents page shows it instead of localhost.
# PANEL_PUBLIC_BASE_URL=https://your-subdomain.trycloudflare.com

# Optional: require this on all /api and /ws except /api/health and public agent device routes.
# HTTP: X-Panel-Api-Key or Authorization: Bearer …  WebSocket: ?panel_key=…
# Dev with Vite: set PANEL_API_KEY in frontend/.env (Vite injects it on proxied /api and /ws).
# PANEL_API_KEY=

# Remote agent admin API + WebSocket auth. If backend/data/agent_admin_key.txt exists (e.g. saved from UI), it overrides this.
# AGENT_ADMIN_KEY=your-long-random-secret

# Browser UI origin(s) allowed by CORS (comma-separated).
# If unset: defaults to http://localhost:5173 (and 127.0.0.1 / ::1) plus Vite preview :4173 — enough for
# localhost UI + VITE_API_ORIGIN tunnel. Add your public UI tunnel URL when using start-cloudflare-tunnel-ui.ps1, e.g.:
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://YOUR-UI-XXXX.trycloudflare.com

# Operator login (optional). Needs ≥16 chars. Issue JWT in HttpOnly cookie after POST /api/auth/login.
# OPERATOR_JWT_SECRET=

# One-time bootstrap: if operators.json does not exist, creates admin (requires OPERATOR_JWT_SECRET).
# OPERATOR_BOOTSTRAP_ADMIN_USER=admin
# OPERATOR_BOOTSTRAP_PASSWORD=

# Optional: optional secret mixed into SHA-256 for stored device tokens.
# Set once before pairing production agents; changing it invalidates existing agent tokens (re-pair required).
# AGENT_TOKEN_PEPPER=

# Python executable for bridge scripts (optional)
# PYTHON_CMD=python
